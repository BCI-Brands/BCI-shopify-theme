{{ 'section-collection-nav.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign nav_group = collection.metafields.custom.collection_nav_group.value
  assign nav_collections = blank
  assign nav_group_title = blank

  if nav_group != blank
    assign nav_collections = nav_group.nav_collections.value
    assign nav_group_title = nav_group.title.value | default: nav_group.title
  endif
-%}

{%- if nav_group != blank and nav_collections != blank -%}
  {%- style -%}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  {%- endstyle -%}

  <section class="collection-nav color-{{ section.settings.color_scheme }} gradient">
    <div class="page-width section-{{ section.id }}-padding">
      <div class="collection-nav__content">
        {%- if section.settings.show_title and nav_group_title != blank -%}
          <h2 class="collection-nav__title">{{ nav_group_title | escape }}</h2>
        {%- endif -%}

        <ul class="collection-nav__list list-unstyled" role="list">
          {%- for nav_collection in nav_collections -%}
            {%- liquid
              assign is_active = false

              if nav_collection.handle == collection.handle
                assign is_active = true
              endif
            -%}

            <li class="collection-nav__item">
              <a
                href="{{ nav_collection.url }}"
                class="collection-nav__link{% if is_active %} is-active{% endif %}"
                {% if is_active %}
                  aria-current="page"
                {% endif %}
              >
                {{ nav_collection.title | escape }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Collection nav",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show group title",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Collection nav"
    }
  ]
}
{% endschema %}
