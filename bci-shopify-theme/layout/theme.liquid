<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">
  
  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  {% render 'meta-tags' %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'component-product-card.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
  </script>

  <style>
    :root {
      /* ══ MASTER BRAND: BCI BRANDS ══ */
      --color-background: {{ settings.color_background }};
      --color-foreground: {{ settings.color_foreground }};
      --color-primary: {{ settings.color_primary }};
      --color-secondary: {{ settings.color_secondary }};
      --color-accent: {{ settings.color_accent }};
      --color-border: {{ settings.color_border }};
      
      /* ══ BRAND 1 ══ */
      --brand1-primary: {{ settings.brand1_primary }};
      --brand1-secondary: {{ settings.brand1_secondary }};
      --brand1-accent: {{ settings.brand1_accent }};
      
      /* ══ BRAND 2 ══ */
      --brand2-primary: {{ settings.brand2_primary }};
      --brand2-secondary: {{ settings.brand2_secondary }};
      --brand2-accent: {{ settings.brand2_accent }};
      
      /* ══ BRAND 3 ══ */
      --brand3-primary: {{ settings.brand3_primary }};
      --brand3-secondary: {{ settings.brand3_secondary }};
      --brand3-accent: {{ settings.brand3_accent }};
      
      /* ══ BRAND 4 ══ */
      --brand4-primary: {{ settings.brand4_primary }};
      --brand4-secondary: {{ settings.brand4_secondary }};
      --brand4-accent: {{ settings.brand4_accent }};
      
      /* ══ BRAND 5 ══ */
      --brand5-primary: {{ settings.brand5_primary }};
      --brand5-secondary: {{ settings.brand5_secondary }};
      --brand5-accent: {{ settings.brand5_accent }};
      
      /* ══ TYPOGRAPHY ══ */
      --font-display: 'Instrument Serif', Georgia, serif;
      --font-heading: 'Cormorant Garamond', Georgia, serif;
      --font-body: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      
      /* ══ SPACING ══ */
      --spacing-xs: 0.25rem;
      --spacing-sm: 0.5rem;
      --spacing-md: 1rem;
      --spacing-lg: 1.5rem;
      --spacing-xl: 2rem;
      --spacing-2xl: 3rem;
      --spacing-3xl: 4rem;
      --spacing-4xl: 6rem;
      
      /* ══ LAYOUT ══ */
      --page-width: 1440px;
      --header-height: 60px;
      --brand-nav-height: 44px;
      
      /* ══ TRANSITIONS ══ */
      --duration-short: 150ms;
      --duration-default: 300ms;
      --duration-long: 500ms;
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    }
  </style>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}"
      data-active-brand="{{ product.vendor | handle | default: collection.handle | default: 'all' }}">
  
  <a class="skip-to-content-link visually-hidden" href="#MainContent">
    {{ "accessibility.skip_to_text" | t }}
  </a>

  {% sections 'header-group' %}

  <main id="MainContent" class="main-content" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  <!-- Cart Drawer -->
  {% render 'cart-drawer' %}
  
  <!-- Quick View Modal -->
  {% render 'quick-view-modal' %}
  
  <!-- Search Modal -->
  {% render 'search-modal' %}

  <script src="{{ 'global.js' | asset_url }}" defer></script>
  <script src="{{ 'cart.js' | asset_url }}" defer></script>

  {%- if request.design_mode -%}
    <script src="{{ 'theme-editor.js' | asset_url }}" defer></script>
  {%- endif -%}
</body>
</html>
