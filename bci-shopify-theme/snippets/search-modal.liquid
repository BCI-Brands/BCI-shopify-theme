{% comment %}
  Search Modal Snippet
  Full-screen search overlay
{% endcomment %}

<div class="search-modal" data-search-modal aria-hidden="true">
  <div class="search-modal__overlay" data-search-close></div>
  <div class="search-modal__content">
    <form action="{{ routes.search_url }}" method="get" class="search-modal__form" role="search">
      <input type="hidden" name="type" value="product">
      <input type="search" 
             name="q" 
             id="search-input"
             class="search-modal__input"
             placeholder="{{ 'general.search.placeholder' | t | default: 'Search products...' }}"
             autocomplete="off"
             autocorrect="off"
             autocapitalize="off"
             spellcheck="false"
             aria-label="{{ 'general.search.search' | t | default: 'Search' }}">
      <button type="submit" class="search-modal__submit" aria-label="{{ 'general.search.search' | t | default: 'Search' }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
      </button>
      <button type="button" class="search-modal__close" data-search-close aria-label="{{ 'general.accessibility.close' | t | default: 'Close' }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>
    </form>
    
    <!-- Search Results -->
    <div class="search-modal__results" data-search-results></div>
    
    <!-- Popular Searches -->
    <div class="search-modal__popular" data-search-popular>
      <h3 class="search-modal__popular-title">Popular Searches</h3>
      <div class="search-modal__popular-tags">
        <a href="/search?type=product&q=dresses" class="search-modal__tag">Dresses</a>
        <a href="/search?type=product&q=blazers" class="search-modal__tag">Blazers</a>
        <a href="/search?type=product&q=trousers" class="search-modal__tag">Trousers</a>
        <a href="/search?type=product&q=new+arrivals" class="search-modal__tag">New Arrivals</a>
        <a href="/search?type=product&q=sale" class="search-modal__tag">Sale</a>
      </div>
    </div>
  </div>
</div>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-default), visibility var(--duration-default);
  }
  
  .search-modal--open {
    opacity: 1;
    visibility: visible;
  }
  
  .search-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }
  
  .search-modal__content {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    background: var(--color-background);
    padding: var(--spacing-xl) var(--spacing-lg);
    transform: translateY(-100%);
    transition: transform var(--duration-default) var(--ease-out);
  }
  
  .search-modal--open .search-modal__content {
    transform: translateY(0);
  }
  
  .search-modal__form {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    max-width: 800px;
    margin: 0 auto;
  }
  
  .search-modal__input {
    flex: 1;
    padding: var(--spacing-md) 0;
    font-family: var(--font-body);
    font-size: 1.25rem;
    border: none;
    border-bottom: 1px solid var(--color-border);
    background: transparent;
    outline: none;
    transition: border-color var(--duration-short);
  }
  
  .search-modal__input:focus {
    border-bottom-color: var(--color-foreground);
  }
  
  .search-modal__input::placeholder {
    color: #999;
  }
  
  .search-modal__submit,
  .search-modal__close {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: opacity var(--duration-short);
  }
  
  .search-modal__submit:hover,
  .search-modal__close:hover {
    opacity: 0.6;
  }
  
  .search-modal__submit svg,
  .search-modal__close svg {
    width: 24px;
    height: 24px;
  }
  
  .search-modal__results {
    max-width: 800px;
    margin: var(--spacing-xl) auto 0;
    display: none;
  }
  
  .search-modal__results.has-results {
    display: block;
  }
  
  .search-modal__popular {
    max-width: 800px;
    margin: var(--spacing-2xl) auto 0;
    text-align: center;
  }
  
  .search-modal__popular-title {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
    margin-bottom: var(--spacing-md);
  }
  
  .search-modal__popular-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-sm);
  }
  
  .search-modal__tag {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: 0.8125rem;
    border: 1px solid var(--color-border);
    transition: all var(--duration-short);
  }
  
  .search-modal__tag:hover {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }
</style>
