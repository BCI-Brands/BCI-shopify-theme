{% comment %}
  Quick View Modal Snippet
  Modal for quick product preview
{% endcomment %}

<div class="quick-view-modal" data-quick-view-modal>
  <div class="quick-view-modal__overlay" data-quick-view-close></div>
  <div class="quick-view-modal__content">
    <button class="quick-view-modal__close" data-quick-view-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>
    <div class="quick-view-modal__body" data-quick-view-content>
      <!-- Content loaded dynamically -->
    </div>
  </div>
</div>

<style>
  .quick-view-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-lg);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--duration-default), visibility var(--duration-default);
  }
  
  .quick-view-modal--open {
    opacity: 1;
    visibility: visible;
  }
  
  .quick-view-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }
  
  .quick-view-modal__content {
    position: relative;
    width: 100%;
    max-width: 900px;
    max-height: 90vh;
    background: var(--color-background);
    overflow: auto;
    transform: scale(0.95);
    transition: transform var(--duration-default) var(--ease-out);
  }
  
  .quick-view-modal--open .quick-view-modal__content {
    transform: scale(1);
  }
  
  .quick-view-modal__close {
    position: absolute;
    top: var(--spacing-md);
    right: var(--spacing-md);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }
  
  .quick-view-modal__close svg {
    width: 24px;
    height: 24px;
  }
  
  .quick-view-modal__body {
    padding: var(--spacing-2xl);
  }
</style>
