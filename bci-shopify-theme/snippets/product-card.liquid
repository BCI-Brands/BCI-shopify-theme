{% comment %}
  Product Card Snippet
  
  Accepts:
  - product: {Object} Product Liquid object
  - show_brand: {Boolean} Show vendor/brand name
  - show_quick_add: {Boolean} Show quick add button
  - lazy_load: {Boolean} Lazy load images (default: true)
  - card_style: {String} 'default', 'compact', 'featured'
{% endcomment %}

{%- liquid
  assign show_brand = show_brand | default: true
  assign show_quick_add = show_quick_add | default: true
  assign lazy_load = lazy_load | default: true
  assign card_style = card_style | default: 'default'
  
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = product.featured_media
  assign hover_image = product.media[1]
  
  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
  
  assign brand_index = 1
  case product.vendor | handle
    when 'brand-one'
      assign brand_index = 1
    when 'brand-two'
      assign brand_index = 2
    when 'brand-three'
      assign brand_index = 3
    when 'brand-four'
      assign brand_index = 4
    when 'brand-five'
      assign brand_index = 5
  endcase
-%}

<div class="product-card product-card--{{ card_style }}" data-product-card data-brand="{{ brand_index }}">
  <a href="{{ product.url }}" class="product-card__link">
    <div class="product-card__media">
      <!-- Badges -->
      <div class="product-card__badges">
        {%- if product.available == false -%}
          <span class="product-card__badge">Sold Out</span>
        {%- elsif on_sale -%}
          <span class="product-card__badge product-card__badge--sale">Sale</span>
        {%- elsif product.created_at > 'now' | date: '%s' | minus: 2592000 | date: '%Y-%m-%d' -%}
          <span class="product-card__badge product-card__badge--new">New</span>
        {%- endif -%}
      </div>
      
      <!-- Primary Image -->
      {%- if featured_image != blank -%}
        <img 
          class="product-card__image product-card__image--primary"
          src="{{ featured_image | image_url: width: 600 }}"
          srcset="{{ featured_image | image_url: width: 300 }} 300w,
                  {{ featured_image | image_url: width: 450 }} 450w,
                  {{ featured_image | image_url: width: 600 }} 600w,
                  {{ featured_image | image_url: width: 900 }} 900w"
          sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
          alt="{{ featured_image.alt | escape | default: product.title }}"
          width="{{ featured_image.width }}"
          height="{{ featured_image.height }}"
          loading="{{ lazy_load | default: true | ternary: 'lazy', 'eager' }}">
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg product-card__image' }}
      {%- endif -%}
      
      <!-- Hover Image -->
      {%- if hover_image != blank -%}
        <img 
          class="product-card__image product-card__image--hover"
          src="{{ hover_image | image_url: width: 600 }}"
          srcset="{{ hover_image | image_url: width: 300 }} 300w,
                  {{ hover_image | image_url: width: 450 }} 450w,
                  {{ hover_image | image_url: width: 600 }} 600w"
          sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
          alt="{{ hover_image.alt | escape | default: product.title }}"
          width="{{ hover_image.width }}"
          height="{{ hover_image.height }}"
          loading="lazy">
      {%- endif -%}
      
      <!-- Wishlist Button -->
      <button class="product-card__wishlist" aria-label="Add to wishlist" data-wishlist-toggle data-product-id="{{ product.id }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
      </button>
      
      <!-- Quick Add Actions -->
      {%- if show_quick_add and product.available -%}
        <div class="product-card__actions">
          {%- if product.variants.size == 1 -%}
            <button class="product-card__quick-add" data-quick-add data-variant-id="{{ current_variant.id }}">
              Add to Bag
            </button>
          {%- else -%}
            <div class="product-card__quick-sizes">
              {%- for variant in product.variants -%}
                {%- if variant.option1 != blank -%}
                  <button 
                    class="product-card__size{% unless variant.available %} product-card__size--unavailable{% endunless %}"
                    data-quick-add
                    data-variant-id="{{ variant.id }}"
                    {% unless variant.available %}disabled{% endunless %}>
                    {{ variant.option1 }}
                  </button>
                {%- endif -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </a>
  
  <div class="product-card__info">
    {%- if show_brand and product.vendor != blank -%}
      <span class="product-card__brand">{{ product.vendor }}</span>
    {%- endif -%}
    
    <a href="{{ product.url }}" class="product-card__title-link">
      <h3 class="product-card__title">{{ product.title }}</h3>
    </a>
    
    <div class="product-card__price">
      {%- if on_sale -%}
        <span class="product-card__price-current product-card__price-current--sale">
          {{ current_variant.price | money }}
        </span>
        <span class="product-card__price-compare">
          {{ current_variant.compare_at_price | money }}
        </span>
        {%- assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
        <span class="product-card__price-discount">-{{ discount }}%</span>
      {%- else -%}
        <span class="product-card__price-current">
          {%- if product.price_varies -%}
            From {{ product.price_min | money }}
          {%- else -%}
            {{ current_variant.price | money }}
          {%- endif -%}
        </span>
      {%- endif -%}
    </div>
    
    <!-- Color Swatches -->
    {%- assign color_option_index = nil -%}
    {%- for option in product.options_with_values -%}
      {%- assign option_name = option.name | downcase -%}
      {%- if option_name == 'color' or option_name == 'colour' -%}
        {%- assign color_option_index = forloop.index0 -%}
      {%- endif -%}
    {%- endfor -%}
    
    {%- if color_option_index != nil -%}
      <div class="product-card__colors">
        {%- assign displayed_colors = '' -%}
        {%- for variant in product.variants -%}
          {%- assign color = variant.options[color_option_index] -%}
          {%- unless displayed_colors contains color -%}
            {%- assign color_handle = color | handle -%}
            <span class="product-card__color" 
                  style="background-color: {{ color_handle }};"
                  title="{{ color }}"
                  data-color="{{ color }}"></span>
            {%- assign displayed_colors = displayed_colors | append: color | append: ',' -%}
          {%- endunless -%}
        {%- endfor -%}
        
        {%- assign color_count = displayed_colors | split: ',' | size | minus: 1 -%}
        {%- if color_count > 4 -%}
          <span class="product-card__color-count">+{{ color_count | minus: 4 }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>
