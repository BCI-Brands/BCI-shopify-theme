{% comment %}
  Main Cart Section
  Full cart page
{% endcomment %}

<section class="main-cart section-padding">
  <div class="page-width">
    <h1 class="cart-page__title">Your Bag</h1>
    
    {%- if cart.item_count > 0 -%}
      <div class="cart-page__layout">
        <!-- Cart Items -->
        <div class="cart-page__items">
          <div class="cart-page__header">
            <span>Product</span>
            <span>Price</span>
            <span>Quantity</span>
            <span>Total</span>
          </div>
          
          {%- for item in cart.items -%}
            <div class="cart-page__item" data-line-key="{{ item.key }}">
              <div class="cart-page__item-product">
                <a href="{{ item.url }}" class="cart-page__item-image">
                  {%- if item.image -%}
                    <img src="{{ item.image | image_url: width: 200 }}" 
                         alt="{{ item.title | escape }}"
                         loading="lazy"
                         width="100"
                         height="133">
                  {%- endif -%}
                </a>
                <div class="cart-page__item-details">
                  <span class="cart-page__item-brand">{{ item.vendor }}</span>
                  <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <span class="cart-page__item-variant">{{ item.variant.title }}</span>
                  {%- endunless -%}
                  <button class="cart-page__item-remove" onclick="removeCartItem('{{ item.key }}')">Remove</button>
                </div>
              </div>
              
              <div class="cart-page__item-price">
                {{ item.final_price | money }}
              </div>
              
              <div class="cart-page__item-quantity">
                <div class="quantity-selector">
                  <button class="quantity-selector__btn" onclick="updateCartQuantity('{{ item.key }}', {{ item.quantity | minus: 1 }})">−</button>
                  <span class="quantity-selector__value">{{ item.quantity }}</span>
                  <button class="quantity-selector__btn" onclick="updateCartQuantity('{{ item.key }}', {{ item.quantity | plus: 1 }})">+</button>
                </div>
              </div>
              
              <div class="cart-page__item-total">
                {{ item.final_line_price | money }}
              </div>
            </div>
          {%- endfor -%}
        </div>
        
        <!-- Cart Summary -->
        <div class="cart-page__summary">
          <h2 class="cart-page__summary-title">Order Summary</h2>
          
          <div class="cart-page__summary-row">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          
          <div class="cart-page__summary-row cart-page__summary-row--note">
            <span>Shipping</span>
            <span>Calculated at checkout</span>
          </div>
          
          <div class="cart-page__summary-row cart-page__summary-total">
            <span>Total</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          
          <a href="/checkout" class="btn btn--primary btn--full btn--large">Checkout</a>
          
          <a href="/collections/all" class="cart-page__continue">Continue Shopping</a>
        </div>
      </div>
    {%- else -%}
      <div class="cart-page__empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <h2>Your bag is empty</h2>
        <p>Looks like you haven't added anything yet.</p>
        <a href="/collections/all" class="btn btn--primary">Start Shopping</a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .cart-page__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 400;
    text-align: center;
    margin-bottom: var(--spacing-2xl);
  }
  
  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2xl);
  }
  
  @media (min-width: 1024px) {
    .cart-page__layout {
      grid-template-columns: 1fr 380px;
    }
  }
  
  .cart-page__header {
    display: none;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #888;
  }
  
  @media (min-width: 768px) {
    .cart-page__header {
      display: grid;
    }
  }
  
  .cart-page__item {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-md);
    padding: var(--spacing-lg) 0;
    border-bottom: 1px solid var(--color-border);
  }
  
  @media (min-width: 768px) {
    .cart-page__item {
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: var(--spacing-lg);
      align-items: center;
    }
  }
  
  .cart-page__item-product {
    display: flex;
    gap: var(--spacing-md);
  }
  
  .cart-page__item-image {
    width: 100px;
    flex-shrink: 0;
  }
  
  .cart-page__item-image img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
  }
  
  .cart-page__item-details {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }
  
  .cart-page__item-brand {
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
  }
  
  .cart-page__item-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
  }
  
  .cart-page__item-variant {
    font-size: 0.8125rem;
    color: #666;
  }
  
  .cart-page__item-remove {
    font-size: 0.75rem;
    text-decoration: underline;
    text-underline-offset: 3px;
    color: #666;
    margin-top: var(--spacing-sm);
    text-align: left;
  }
  
  .cart-page__item-price,
  .cart-page__item-total {
    font-size: 0.9375rem;
    font-weight: 500;
  }
  
  .cart-page__item-quantity .quantity-selector {
    display: inline-flex;
    border: 1px solid var(--color-border);
  }
  
  .cart-page__item-quantity .quantity-selector__btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    cursor: pointer;
    background: none;
    border: none;
  }
  
  .cart-page__item-quantity .quantity-selector__value {
    min-width: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
  }
  
  /* Summary */
  .cart-page__summary {
    background: #F8F7F5;
    padding: var(--spacing-xl);
    height: fit-content;
  }
  
  .cart-page__summary-title {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 500;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border);
  }
  
  .cart-page__summary-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--spacing-md);
    font-size: 0.9375rem;
  }
  
  .cart-page__summary-row--note span:last-child {
    color: #666;
    font-size: 0.8125rem;
  }
  
  .cart-page__summary-total {
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
    font-weight: 600;
    font-size: 1.125rem;
  }
  
  .cart-page__summary .btn {
    margin-top: var(--spacing-lg);
  }
  
  .cart-page__continue {
    display: block;
    text-align: center;
    margin-top: var(--spacing-md);
    font-size: 0.8125rem;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  
  /* Empty State */
  .cart-page__empty {
    text-align: center;
    padding: var(--spacing-4xl) var(--spacing-lg);
  }
  
  .cart-page__empty svg {
    width: 48px;
    height: 48px;
    margin-bottom: var(--spacing-lg);
    opacity: 0.3;
  }
  
  .cart-page__empty h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 500;
    margin-bottom: var(--spacing-sm);
  }
  
  .cart-page__empty p {
    color: #666;
    margin-bottom: var(--spacing-xl);
  }
</style>

<script>
  async function updateCartQuantity(key, quantity) {
    try {
      const response = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: quantity })
      });
      if (response.ok) {
        window.location.reload();
      }
    } catch (error) {
      console.error('Error updating cart:', error);
    }
  }
  
  async function removeCartItem(key) {
    await updateCartQuantity(key, 0);
  }
</script>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
