{% comment %}
  Hero Section - Theory-inspired
  Supports: Full-width hero, split hero, video backgrounds
{% endcomment %}

{%- liquid
  assign hero_height = section.settings.height
  assign text_color = section.settings.text_color
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0
-%}

{%- style -%}
  #Hero-{{ section.id }} {
    --hero-height: {% case hero_height %}{% when 'small' %}50vh{% when 'medium' %}70vh{% when 'large' %}90vh{% when 'full' %}100vh{% endcase %};
    --text-color: {{ text_color }};
    --overlay-opacity: {{ overlay_opacity }};
  }
{%- endstyle -%}

{%- if section.settings.layout == 'split' -%}
  <!-- Split Hero Layout -->
  <section id="Hero-{{ section.id }}" class="split-hero">
    {%- for block in section.blocks -%}
      {%- if block.type == 'split_panel' -%}
        <a href="{{ block.settings.link }}" class="split-hero__panel" {{ block.shopify_attributes }}>
          <div class="split-hero__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 1200 }}"
                   srcset="{{ block.settings.image | image_url: width: 600 }} 600w,
                           {{ block.settings.image | image_url: width: 900 }} 900w,
                           {{ block.settings.image | image_url: width: 1200 }} 1200w"
                   sizes="(max-width: 768px) 100vw, 50vw"
                   alt="{{ block.settings.image.alt | escape }}"
                   loading="eager"
                   width="{{ block.settings.image.width }}"
                   height="{{ block.settings.image.height }}">
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="split-hero__overlay"></div>
          <div class="split-hero__content">
            {%- if block.settings.overline != blank -%}
              <span class="hero__overline">{{ block.settings.overline }}</span>
            {%- endif -%}
            <h2 class="split-hero__title">{{ block.settings.title }}</h2>
            {%- if block.settings.button_text != blank -%}
              <span class="btn btn--outline-white">{{ block.settings.button_text }}</span>
            {%- endif -%}
          </div>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </section>

{%- else -%}
  <!-- Full Width Hero -->
  <section id="Hero-{{ section.id }}" class="hero hero--{{ hero_height }}">
    <div class="hero__media">
      {%- if section.settings.video != blank -%}
        <video autoplay muted loop playsinline>
          <source src="{{ section.settings.video }}" type="video/mp4">
        </video>
      {%- elsif section.settings.image != blank -%}
        <img src="{{ section.settings.image | image_url: width: 2400 }}"
             srcset="{{ section.settings.image | image_url: width: 800 }} 800w,
                     {{ section.settings.image | image_url: width: 1200 }} 1200w,
                     {{ section.settings.image | image_url: width: 1800 }} 1800w,
                     {{ section.settings.image | image_url: width: 2400 }} 2400w"
             sizes="100vw"
             alt="{{ section.settings.image.alt | escape }}"
             loading="eager"
             fetchpriority="high"
             width="{{ section.settings.image.width }}"
             height="{{ section.settings.image.height }}">
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
    
    {%- if section.settings.show_overlay -%}
      <div class="hero__overlay" style="background: linear-gradient(to bottom, rgba(0,0,0,{{ overlay_opacity | minus: 0.1 }}), rgba(0,0,0,{{ overlay_opacity | plus: 0.1 }}));"></div>
    {%- endif -%}
    
    <div class="hero__content" style="color: var(--text-color);">
      {%- if section.settings.overline != blank -%}
        <span class="hero__overline animate-fade-in-up" style="animation-delay: 0ms;">{{ section.settings.overline }}</span>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h1 class="hero__title animate-fade-in-up" style="animation-delay: 100ms;">{{ section.settings.title }}</h1>
      {%- endif -%}
      
      {%- if section.settings.description != blank -%}
        <p class="hero__description animate-fade-in-up" style="animation-delay: 200ms;">{{ section.settings.description }}</p>
      {%- endif -%}
      
      <div class="hero__cta animate-fade-in-up" style="animation-delay: 300ms;">
        {%- if section.settings.button_text != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn btn--white">
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}
        
        {%- if section.settings.button_text_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="btn btn--outline-white">
            {{ section.settings.button_text_2 }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "full", "label": "Full width" },
        { "value": "split", "label": "Split (2 panels)" }
      ],
      "default": "full"
    },
    {
      "type": "header",
      "content": "Full Width Settings"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "video",
      "label": "Video URL",
      "info": "MP4 format recommended"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "small", "label": "Small (50vh)" },
        { "value": "medium", "label": "Medium (70vh)" },
        { "value": "large", "label": "Large (90vh)" },
        { "value": "full", "label": "Full screen" }
      ],
      "default": "large"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay",
      "default": true
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline text",
      "default": "New Collection"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Refined Essentials"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Primary button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "button_text_2",
      "label": "Secondary button text"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Secondary button link"
    }
  ],
  "blocks": [
    {
      "type": "split_panel",
      "name": "Split Panel",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "overline",
          "label": "Overline"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Shop Women"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Explore"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "layout": "full",
        "title": "The New Modern",
        "overline": "Spring 2025",
        "button_text": "Shop Collection"
      }
    },
    {
      "name": "Hero - Split",
      "settings": {
        "layout": "split"
      },
      "blocks": [
        {
          "type": "split_panel",
          "settings": {
            "title": "Shop Women",
            "button_text": "Explore"
          }
        },
        {
          "type": "split_panel",
          "settings": {
            "title": "Shop Men",
            "button_text": "Explore"
          }
        }
      ]
    }
  ]
}
{% endschema %}
