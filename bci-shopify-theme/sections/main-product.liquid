{% comment %}
  Main Product Section
  Product page with images, details, and add to cart
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = current_variant.featured_media | default: product.featured_media
-%}

<section class="main-product section-padding">
  <div class="page-width">
    <div class="product-page">
      <!-- Product Gallery -->
      <div class="product-gallery" data-product-gallery>
        <!-- Thumbnails -->
        {%- if product.media.size > 1 -%}
          <div class="product-gallery__thumbs">
            {%- for media in product.media -%}
              <button class="product-gallery__thumb{% if forloop.first %} product-gallery__thumb--active{% endif %}"
                      data-thumb-index="{{ forloop.index0 }}"
                      aria-label="View image {{ forloop.index }}">
                <img src="{{ media | image_url: width: 100 }}"
                     alt="{{ media.alt | escape }}"
                     loading="lazy"
                     width="60"
                     height="80">
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
        
        <!-- Main Image -->
        <div class="product-gallery__main">
          {%- for media in product.media -%}
            <div class="product-gallery__slide{% if forloop.first %} product-gallery__slide--active{% endif %}"
                 data-slide-index="{{ forloop.index0 }}">
              <img src="{{ media | image_url: width: 1200 }}"
                   srcset="{{ media | image_url: width: 600 }} 600w,
                           {{ media | image_url: width: 900 }} 900w,
                           {{ media | image_url: width: 1200 }} 1200w"
                   sizes="(max-width: 768px) 100vw, 50vw"
                   alt="{{ media.alt | escape }}"
                   loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                   width="{{ media.width }}"
                   height="{{ media.height }}">
            </div>
          {%- endfor -%}
        </div>
      </div>
      
      <!-- Product Info -->
      <div class="product-info">
        <!-- Breadcrumb -->
        <nav class="product-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          {%- if collection -%}
            <a href="{{ collection.url }}">{{ collection.title }}</a>
            <span>/</span>
          {%- endif -%}
          <span>{{ product.title }}</span>
        </nav>
        
        <!-- Brand -->
        {%- if product.vendor != blank -%}
          <a href="/collections/vendors?q={{ product.vendor | url_encode }}" class="product-info__brand">
            {{ product.vendor }}
          </a>
        {%- endif -%}
        
        <!-- Title -->
        <h1 class="product-info__title">{{ product.title }}</h1>
        
        <!-- Price -->
        <div class="product-info__price" data-product-price>
          {%- if current_variant.compare_at_price > current_variant.price -%}
            <span class="product-info__price-current product-info__price-current--sale">
              {{ current_variant.price | money }}
            </span>
            <span class="product-info__price-compare">
              {{ current_variant.compare_at_price | money }}
            </span>
            {%- assign discount = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
            <span class="product-info__price-badge">Save {{ discount }}%</span>
          {%- else -%}
            <span class="product-info__price-current">{{ current_variant.price | money }}</span>
          {%- endif -%}
        </div>
        
        <!-- Product Form -->
        {%- form 'product', product, id: 'product-form', class: 'product-form', data-product-form: '' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
          
          <!-- Variant Options -->
          {%- unless product.has_only_default_variant -%}
            {%- for option in product.options_with_values -%}
              <div class="product-form__option">
                <label class="product-form__label">
                  {{ option.name }}
                  {%- if option.name == 'Size' -%}
                    <a href="#size-guide" class="product-form__size-guide">Size Guide</a>
                  {%- endif -%}
                </label>
                
                <div class="product-form__options">
                  {%- for value in option.values -%}
                    {%- liquid
                      assign option_disabled = true
                      for variant in product.variants
                        if variant.options[forloop.parentloop.index0] == value and variant.available
                          assign option_disabled = false
                          break
                        endif
                      endfor
                    -%}
                    
                    <label class="product-form__swatch{% if option.selected_value == value %} product-form__swatch--selected{% endif %}{% if option_disabled %} product-form__swatch--disabled{% endif %}">
                      <input type="radio" 
                             name="option{{ forloop.parentloop.index }}" 
                             value="{{ value | escape }}"
                             {% if option.selected_value == value %}checked{% endif %}
                             {% if option_disabled %}disabled{% endif %}
                             data-option-input>
                      <span>{{ value }}</span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endfor -%}
          {%- endunless -%}
          
          <!-- Quantity -->
          <div class="product-form__quantity">
            <label class="product-form__label">Quantity</label>
            <div class="quantity-selector">
              <button type="button" class="quantity-selector__btn" data-quantity-minus>−</button>
              <input type="number" 
                     name="quantity" 
                     value="1" 
                     min="1" 
                     class="quantity-selector__input"
                     data-quantity-input>
              <button type="button" class="quantity-selector__btn" data-quantity-plus>+</button>
            </div>
          </div>
          
          <!-- Add to Cart -->
          <button type="submit" 
                  class="btn btn--primary btn--large btn--full product-form__submit"
                  {% unless current_variant.available %}disabled{% endunless %}
                  data-add-to-cart>
            {%- if current_variant.available -%}
              Add to Bag
            {%- else -%}
              Sold Out
            {%- endif -%}
          </button>
          
          <!-- Wishlist -->
          <button type="button" class="product-form__wishlist" data-wishlist-add>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            </svg>
            Add to Wishlist
          </button>
        {%- endform -%}
        
        <!-- Shipping Info -->
        <div class="product-info__shipping">
          <div class="product-info__shipping-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="1" y="3" width="15" height="13"/>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/>
              <circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <span>Free shipping on orders over $150</span>
          </div>
          <div class="product-info__shipping-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="23 4 23 10 17 10"/>
              <polyline points="1 20 1 14 7 14"/>
              <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>
            </svg>
            <span>Free returns within 30 days</span>
          </div>
        </div>
        
        <!-- Product Description -->
        {%- if product.description != blank -%}
          <div class="product-info__description">
            <button class="product-accordion__trigger" data-accordion-trigger aria-expanded="false">
              <span>Description</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
            <div class="product-accordion__content" data-accordion-content>
              {{ product.description }}
            </div>
          </div>
        {%- endif -%}
        
        <!-- Details Accordion -->
        {%- if product.metafields.custom.details -%}
          <div class="product-info__details">
            <button class="product-accordion__trigger" data-accordion-trigger aria-expanded="false">
              <span>Details & Care</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
            <div class="product-accordion__content" data-accordion-content>
              {{ product.metafields.custom.details }}
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
  
  <!-- Product JSON for JS -->
  <script type="application/json" data-product-json>
    {{ product | json }}
  </script>
</section>

<style>
  .product-page {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2xl);
  }
  
  @media (min-width: 1024px) {
    .product-page {
      grid-template-columns: 1.2fr 1fr;
      gap: var(--spacing-3xl);
    }
  }
  
  /* Gallery */
  .product-gallery {
    display: flex;
    gap: var(--spacing-md);
  }
  
  .product-gallery__thumbs {
    display: none;
    flex-direction: column;
    gap: var(--spacing-sm);
    width: 80px;
    flex-shrink: 0;
  }
  
  @media (min-width: 768px) {
    .product-gallery__thumbs {
      display: flex;
    }
  }
  
  .product-gallery__thumb {
    opacity: 0.5;
    transition: opacity var(--duration-short);
    cursor: pointer;
    border: none;
    padding: 0;
    background: none;
  }
  
  .product-gallery__thumb:hover,
  .product-gallery__thumb--active {
    opacity: 1;
  }
  
  .product-gallery__thumb img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
  }
  
  .product-gallery__main {
    flex: 1;
    position: relative;
  }
  
  .product-gallery__slide {
    display: none;
  }
  
  .product-gallery__slide--active {
    display: block;
  }
  
  .product-gallery__slide img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
  }
  
  /* Product Info */
  .product-breadcrumb {
    font-size: 0.75rem;
    color: #888;
    margin-bottom: var(--spacing-lg);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }
  
  .product-breadcrumb a:hover {
    color: var(--color-foreground);
  }
  
  .product-info__brand {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #888;
    display: block;
    margin-bottom: var(--spacing-sm);
  }
  
  .product-info__title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 500;
    line-height: 1.2;
    margin-bottom: var(--spacing-md);
  }
  
  .product-info__price {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
  }
  
  .product-info__price-current {
    font-size: 1.25rem;
    font-weight: 500;
  }
  
  .product-info__price-current--sale {
    color: #8B2635;
  }
  
  .product-info__price-compare {
    text-decoration: line-through;
    color: #999;
  }
  
  .product-info__price-badge {
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 4px 8px;
    background: #8B2635;
    color: #fff;
  }
  
  /* Product Form */
  .product-form__option {
    margin-bottom: var(--spacing-lg);
  }
  
  .product-form__label {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--spacing-sm);
  }
  
  .product-form__size-guide {
    font-weight: 400;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  
  .product-form__options {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }
  
  .product-form__swatch {
    position: relative;
    cursor: pointer;
  }
  
  .product-form__swatch input {
    position: absolute;
    opacity: 0;
  }
  
  .product-form__swatch span {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 44px;
    padding: 0 var(--spacing-md);
    font-size: 0.8125rem;
    border: 1px solid var(--color-border);
    transition: all var(--duration-short);
  }
  
  .product-form__swatch:hover span {
    border-color: var(--color-foreground);
  }
  
  .product-form__swatch--selected span {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }
  
  .product-form__swatch--disabled span {
    opacity: 0.3;
    cursor: not-allowed;
    text-decoration: line-through;
  }
  
  /* Quantity Selector */
  .product-form__quantity {
    margin-bottom: var(--spacing-lg);
  }
  
  .quantity-selector {
    display: inline-flex;
    border: 1px solid var(--color-border);
  }
  
  .quantity-selector__btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    transition: background var(--duration-short);
  }
  
  .quantity-selector__btn:hover {
    background: #f5f5f5;
  }
  
  .quantity-selector__input {
    width: 50px;
    height: 44px;
    text-align: center;
    font-size: 0.9375rem;
    border: none;
    border-left: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    -moz-appearance: textfield;
  }
  
  .quantity-selector__input::-webkit-inner-spin-button,
  .quantity-selector__input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  
  /* Add to Cart */
  .product-form__submit {
    margin-bottom: var(--spacing-md);
  }
  
  .product-form__wishlist {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    width: 100%;
    padding: var(--spacing-md);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    color: #666;
    transition: color var(--duration-short);
  }
  
  .product-form__wishlist:hover {
    color: var(--color-foreground);
  }
  
  .product-form__wishlist svg {
    width: 18px;
    height: 18px;
  }
  
  /* Shipping Info */
  .product-info__shipping {
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }
  
  .product-info__shipping-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: 0.8125rem;
    color: #666;
  }
  
  .product-info__shipping-item svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  
  /* Accordion */
  .product-info__description,
  .product-info__details {
    border-top: 1px solid var(--color-border);
    margin-top: var(--spacing-lg);
  }
  
  .product-accordion__trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--spacing-md) 0;
    font-size: 0.8125rem;
    font-weight: 500;
    text-align: left;
  }
  
  .product-accordion__trigger svg {
    width: 16px;
    height: 16px;
    transition: transform var(--duration-short);
  }
  
  .product-accordion__trigger[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }
  
  .product-accordion__content {
    display: none;
    padding-bottom: var(--spacing-lg);
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #444;
  }
  
  .product-accordion__content.is-open {
    display: block;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Gallery thumbnails
    const thumbs = document.querySelectorAll('[data-thumb-index]');
    const slides = document.querySelectorAll('[data-slide-index]');
    
    thumbs.forEach(thumb => {
      thumb.addEventListener('click', function() {
        const index = this.dataset.thumbIndex;
        
        thumbs.forEach(t => t.classList.remove('product-gallery__thumb--active'));
        slides.forEach(s => s.classList.remove('product-gallery__slide--active'));
        
        this.classList.add('product-gallery__thumb--active');
        document.querySelector(`[data-slide-index="${index}"]`).classList.add('product-gallery__slide--active');
      });
    });
    
    // Quantity buttons
    const quantityInput = document.querySelector('[data-quantity-input]');
    const minusBtn = document.querySelector('[data-quantity-minus]');
    const plusBtn = document.querySelector('[data-quantity-plus]');
    
    if (minusBtn && plusBtn && quantityInput) {
      minusBtn.addEventListener('click', () => {
        const current = parseInt(quantityInput.value);
        if (current > 1) quantityInput.value = current - 1;
      });
      
      plusBtn.addEventListener('click', () => {
        const current = parseInt(quantityInput.value);
        quantityInput.value = current + 1;
      });
    }
    
    // Accordion
    const accordionTriggers = document.querySelectorAll('[data-accordion-trigger]');
    accordionTriggers.forEach(trigger => {
      trigger.addEventListener('click', function() {
        const expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', !expanded);
        this.nextElementSibling.classList.toggle('is-open');
      });
    });
    
    // Variant selection
    const productJson = JSON.parse(document.querySelector('[data-product-json]').textContent);
    const optionInputs = document.querySelectorAll('[data-option-input]');
    const variantIdInput = document.querySelector('[data-variant-id]');
    const addToCartBtn = document.querySelector('[data-add-to-cart]');
    const priceElement = document.querySelector('[data-product-price]');
    
    optionInputs.forEach(input => {
      input.addEventListener('change', function() {
        // Update selected state
        const parent = this.closest('.product-form__options');
        parent.querySelectorAll('.product-form__swatch').forEach(s => s.classList.remove('product-form__swatch--selected'));
        this.closest('.product-form__swatch').classList.add('product-form__swatch--selected');
        
        // Find matching variant
        const selectedOptions = Array.from(document.querySelectorAll('[data-option-input]:checked')).map(i => i.value);
        const variant = productJson.variants.find(v => {
          return v.options.every((opt, index) => opt === selectedOptions[index]);
        });
        
        if (variant) {
          variantIdInput.value = variant.id;
          
          // Update price
          if (variant.compare_at_price > variant.price) {
            priceElement.innerHTML = `
              <span class="product-info__price-current product-info__price-current--sale">${formatMoney(variant.price)}</span>
              <span class="product-info__price-compare">${formatMoney(variant.compare_at_price)}</span>
            `;
          } else {
            priceElement.innerHTML = `<span class="product-info__price-current">${formatMoney(variant.price)}</span>`;
          }
          
          // Update button
          if (variant.available) {
            addToCartBtn.disabled = false;
            addToCartBtn.textContent = 'Add to Bag';
          } else {
            addToCartBtn.disabled = true;
            addToCartBtn.textContent = 'Sold Out';
          }
          
          // Update URL
          const url = new URL(window.location.href);
          url.searchParams.set('variant', variant.id);
          window.history.replaceState({}, '', url);
        }
      });
    });
    
    function formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }
    
    // Add to cart AJAX
    const productForm = document.querySelector('[data-product-form]');
    if (productForm) {
      productForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const formData = new FormData(this);
        addToCartBtn.disabled = true;
        addToCartBtn.textContent = 'Adding...';
        
        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            body: formData
          });
          
          if (response.ok) {
            addToCartBtn.textContent = 'Added!';
            
            // Open cart drawer
            if (typeof CartDrawer !== 'undefined') {
              CartDrawer.open();
            }
            
            setTimeout(() => {
              addToCartBtn.disabled = false;
              addToCartBtn.textContent = 'Add to Bag';
            }, 1500);
          } else {
            throw new Error('Failed to add to cart');
          }
        } catch (error) {
          console.error(error);
          addToCartBtn.textContent = 'Error';
          setTimeout(() => {
            addToCartBtn.disabled = false;
            addToCartBtn.textContent = 'Add to Bag';
          }, 1500);
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Product Information",
  "tag": "section",
  "class": "main-product-section"
}
{% endschema %}
