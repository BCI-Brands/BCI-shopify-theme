{% comment %}
  Footer Section
  Multi-column footer with brand information, navigation, and social links
{% endcomment %}

<footer class="footer">
  <div class="page-width">
    <div class="footer__grid">
      <!-- Brand Column -->
      <div class="footer__brand">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" 
               alt="{{ shop.name }}"
               class="footer__logo-image"
               loading="lazy">
        {%- else -%}
          <div class="footer__logo">{{ shop.name }}</div>
        {%- endif -%}
        
        {%- if section.settings.tagline != blank -%}
          <p class="footer__tagline">{{ section.settings.tagline }}</p>
        {%- endif -%}
      </div>
      
      <!-- Navigation Columns -->
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'menu' -%}
            <div class="footer__column" {{ block.shopify_attributes }}>
              <h4 class="footer__column-title">{{ block.settings.title }}</h4>
              {%- if block.settings.menu != blank -%}
                <ul class="footer__links">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li>
                      <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          
          {%- when 'brands' -%}
            <div class="footer__column" {{ block.shopify_attributes }}>
              <h4 class="footer__column-title">{{ block.settings.title | default: 'Our Brands' }}</h4>
              <ul class="footer__links">
                {%- if block.settings.brand_1_name != blank -%}
                  <li><a href="{{ block.settings.brand_1_link }}" class="footer__link">{{ block.settings.brand_1_name }}</a></li>
                {%- endif -%}
                {%- if block.settings.brand_2_name != blank -%}
                  <li><a href="{{ block.settings.brand_2_link }}" class="footer__link">{{ block.settings.brand_2_name }}</a></li>
                {%- endif -%}
                {%- if block.settings.brand_3_name != blank -%}
                  <li><a href="{{ block.settings.brand_3_link }}" class="footer__link">{{ block.settings.brand_3_name }}</a></li>
                {%- endif -%}
                {%- if block.settings.brand_4_name != blank -%}
                  <li><a href="{{ block.settings.brand_4_link }}" class="footer__link">{{ block.settings.brand_4_name }}</a></li>
                {%- endif -%}
                {%- if block.settings.brand_5_name != blank -%}
                  <li><a href="{{ block.settings.brand_5_link }}" class="footer__link">{{ block.settings.brand_5_name }}</a></li>
                {%- endif -%}
              </ul>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
    
    <!-- Bottom Bar -->
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      
      <!-- Social Links -->
      {%- if section.settings.show_social -%}
        <div class="footer__social">
          {%- if section.settings.social_instagram != blank -%}
            <a href="{{ section.settings.social_instagram }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </a>
          {%- endif -%}
          
          {%- if section.settings.social_facebook != blank -%}
            <a href="{{ section.settings.social_facebook }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
            </a>
          {%- endif -%}
          
          {%- if section.settings.social_pinterest != blank -%}
            <a href="{{ section.settings.social_pinterest }}" class="footer__social-link" aria-label="Pinterest" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"/>
                <path d="M8 12c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4"/>
                <path d="M12 12v6"/>
              </svg>
            </a>
          {%- endif -%}
          
          {%- if section.settings.social_tiktok != blank -%}
            <a href="{{ section.settings.social_tiktok }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M9 12a4 4 0 104 4V4c.5 2.5 2.5 4 5 4"/>
              </svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "footer-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Tagline",
      "default": "Curating distinctive style across five unique brands. Quality craftsmanship meets modern design."
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "Pinterest URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu Column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "brands",
      "name": "Brands Column",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Our Brands"
        },
        {
          "type": "text",
          "id": "brand_1_name",
          "label": "Brand 1 name"
        },
        {
          "type": "url",
          "id": "brand_1_link",
          "label": "Brand 1 link"
        },
        {
          "type": "text",
          "id": "brand_2_name",
          "label": "Brand 2 name"
        },
        {
          "type": "url",
          "id": "brand_2_link",
          "label": "Brand 2 link"
        },
        {
          "type": "text",
          "id": "brand_3_name",
          "label": "Brand 3 name"
        },
        {
          "type": "url",
          "id": "brand_3_link",
          "label": "Brand 3 link"
        },
        {
          "type": "text",
          "id": "brand_4_name",
          "label": "Brand 4 name"
        },
        {
          "type": "url",
          "id": "brand_4_link",
          "label": "Brand 4 link"
        },
        {
          "type": "text",
          "id": "brand_5_name",
          "label": "Brand 5 name"
        },
        {
          "type": "url",
          "id": "brand_5_link",
          "label": "Brand 5 link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "brands",
          "settings": {
            "brand_1_name": "Brand One",
            "brand_2_name": "Brand Two",
            "brand_3_name": "Brand Three",
            "brand_4_name": "Brand Four",
            "brand_5_name": "Brand Five"
          }
        },
        {
          "type": "menu",
          "settings": {
            "title": "Customer Care"
          }
        },
        {
          "type": "menu",
          "settings": {
            "title": "Company"
          }
        },
        {
          "type": "menu",
          "settings": {
            "title": "Legal"
          }
        }
      ]
    }
  ]
}
{% endschema %}
