{% comment %}
  Brand Showcase Section
  Displays all 5 brands in a visually engaging grid
{% endcomment %}

<section class="brand-showcase-section section-padding">
  <div class="page-width">
    {%- if section.settings.show_header -%}
      <div class="section-header">
        {%- if section.settings.overline != blank -%}
          <p class="section-header__overline">{{ section.settings.overline }}</p>
        {%- endif -%}
        <h2 class="section-header__title">{{ section.settings.title }}</h2>
        {%- if section.settings.description != blank -%}
          <p class="section-header__description">{{ section.settings.description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
  
  <div class="brand-showcase">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link }}" class="brand-showcase__item" {{ block.shopify_attributes }}>
        <div class="brand-showcase__media">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}"
                 srcset="{{ block.settings.image | image_url: width: 400 }} 400w,
                         {{ block.settings.image | image_url: width: 600 }} 600w,
                         {{ block.settings.image | image_url: width: 800 }} 800w"
                 sizes="(max-width: 768px) 100vw, 20vw"
                 alt="{{ block.settings.name }}"
                 loading="lazy"
                 width="{{ block.settings.image.width }}"
                 height="{{ block.settings.image.height }}">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
        <div class="brand-showcase__overlay"></div>
        <div class="brand-showcase__content">
          <h3 class="brand-showcase__name">{{ block.settings.name }}</h3>
          {%- if block.settings.tagline != blank -%}
            <p class="brand-showcase__tagline">{{ block.settings.tagline }}</p>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Brand Showcase",
  "tag": "section",
  "class": "brand-showcase-wrapper",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show section header",
      "default": true
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline text",
      "default": "Discover"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Brands"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Brand name",
          "default": "Brand Name"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline",
          "default": "Shop the collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Showcase",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "name": "Brand One",
            "tagline": "Modern Sophistication"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Brand Two",
            "tagline": "Timeless Elegance"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Brand Three",
            "tagline": "Contemporary Style"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Brand Four",
            "tagline": "Refined Classics"
          }
        },
        {
          "type": "brand",
          "settings": {
            "name": "Brand Five",
            "tagline": "Effortless Chic"
          }
        }
      ]
    }
  ]
}
{% endschema %}
