{% comment %}
  BCI Brands Header Section
  Includes: Announcement bar, main header, brand navigation, category navigation
{% endcomment %}

{%- style -%}
  .header-section {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: {{ section.settings.background_color }};
  }
{%- endstyle -%}

<header class="header-section" data-header>
  {%- if section.settings.show_announcement -%}
    <div class="announcement-bar">
      <div class="page-width">
        <p>
          {{ section.settings.announcement_text }}
          {%- if section.settings.announcement_link != blank -%}
            <a href="{{ section.settings.announcement_link }}">{{ section.settings.announcement_link_text }}</a>
          {%- endif -%}
        </p>
      </div>
    </div>
  {%- endif -%}

  <!-- Main Header Bar -->
  <div class="header__main">
    <div class="header__left">
      <!-- Mobile Menu Toggle -->
      <button class="header__menu-toggle" aria-expanded="false" aria-controls="mobile-menu" data-mobile-menu-toggle>
        <span></span>
        <span></span>
        <span></span>
      </button>

      <!-- Logo -->
      <a href="{{ routes.root_url }}" class="header__logo">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}" 
               alt="{{ shop.name }}"
               width="{{ section.settings.logo.width }}"
               height="{{ section.settings.logo.height }}"
               loading="eager">
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>
    </div>

    <div class="header__right">
      <!-- Search -->
      <button class="header__icon" aria-label="{{ 'general.search.search' | t }}" data-search-toggle>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
      </button>

      <!-- Account -->
      <a href="{{ routes.account_url }}" class="header__icon" aria-label="{{ 'customer.account.title' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>

      <!-- Cart -->
      <button class="header__icon" aria-label="{{ 'sections.cart.title' | t }}" data-cart-toggle style="position: relative;">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        <span class="header__cart-count" data-cart-count>{{ cart.item_count }}</span>
      </button>
    </div>
  </div>

  <!-- Brand Navigation -->
  <nav class="brand-nav" aria-label="Brand navigation">
    {%- for block in section.blocks -%}
      {%- if block.type == 'brand' -%}
        <a href="{{ block.settings.brand_link }}" 
           class="brand-nav__item{% if request.path contains block.settings.brand_handle %} brand-nav__item--active{% endif %}"
           data-brand="{{ forloop.index }}"
           {{ block.shopify_attributes }}>
          {{ block.settings.brand_name }}
        </a>
      {%- endif -%}
    {%- endfor -%}
  </nav>

  <!-- Main Category Navigation (Desktop) -->
  <nav class="main-nav" aria-label="Main navigation">
    {%- for link in linklists[section.settings.main_menu].links -%}
      <div class="main-nav__item-wrapper" style="position: relative;">
        <a href="{{ link.url }}" class="main-nav__item">
          {{ link.title }}
        </a>
        
        {%- if link.links.size > 0 -%}
          <div class="mega-menu">
            <div class="mega-menu__grid">
              {%- for childlink in link.links -%}
                <div class="mega-menu__column">
                  <h4>{{ childlink.title }}</h4>
                  {%- if childlink.links.size > 0 -%}
                    <div class="mega-menu__links">
                      {%- for grandchildlink in childlink.links -%}
                        <a href="{{ grandchildlink.url }}" class="mega-menu__link">{{ grandchildlink.title }}</a>
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </nav>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobile-menu" data-mobile-menu>
  <div class="mobile-menu__inner">
    <!-- Brand Links -->
    <div class="mobile-menu__brands">
      {%- for block in section.blocks -%}
        {%- if block.type == 'brand' -%}
          <a href="{{ block.settings.brand_link }}" class="mobile-menu__brand-link">
            {{ block.settings.brand_name }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
    
    <!-- Main Menu Links -->
    <nav class="mobile-menu__nav">
      {%- for link in linklists[section.settings.main_menu].links -%}
        <div class="mobile-menu__item">
          <a href="{{ link.url }}" class="mobile-menu__link">{{ link.title }}</a>
          {%- if link.links.size > 0 -%}
            <button class="mobile-menu__expand" aria-expanded="false">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </button>
          {%- endif -%}
        </div>
        {%- if link.links.size > 0 -%}
          <div class="mobile-menu__submenu">
            {%- for childlink in link.links -%}
              <a href="{{ childlink.url }}" class="mobile-menu__sublink">{{ childlink.title }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </nav>
    
    <!-- Account Links -->
    <div class="mobile-menu__account">
      {%- if customer -%}
        <a href="{{ routes.account_url }}">My Account</a>
        <a href="{{ routes.account_logout_url }}">Log Out</a>
      {%- else -%}
        <a href="{{ routes.account_login_url }}">Log In</a>
        <a href="{{ routes.account_register_url }}">Create Account</a>
      {%- endif -%}
    </div>
  </div>
</div>

<style>
  /* Mobile Menu Styles */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 100%;
    max-width: 380px;
    background: var(--color-background);
    z-index: 9999;
    transform: translateX(-100%);
    transition: transform var(--duration-default) var(--ease-out);
    overflow-y: auto;
  }
  
  .mobile-menu--open {
    transform: translateX(0);
  }
  
  .mobile-menu__inner {
    padding: calc(var(--header-height) + var(--spacing-xl)) var(--spacing-lg) var(--spacing-xl);
  }
  
  .mobile-menu__brands {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
  }
  
  .mobile-menu__brand-link {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    background: #F5F4F2;
  }
  
  .mobile-menu__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border);
  }
  
  .mobile-menu__link {
    flex: 1;
    padding: var(--spacing-md) 0;
    font-size: 1rem;
  }
  
  .mobile-menu__expand {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .mobile-menu__expand svg {
    transition: transform var(--duration-short);
  }
  
  .mobile-menu__expand[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }
  
  .mobile-menu__submenu {
    display: none;
    flex-direction: column;
    padding-left: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
  }
  
  .mobile-menu__submenu--open {
    display: flex;
  }
  
  .mobile-menu__sublink {
    padding: var(--spacing-sm) 0;
    font-size: 0.875rem;
    color: #666;
  }
  
  .mobile-menu__account {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
  }
  
  .mobile-menu__account a {
    font-size: 0.875rem;
    color: #666;
  }
  
  @media (min-width: 1024px) {
    .mobile-menu {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Header",
  "class": "header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "link_list",
      "id": "main_menu",
      "label": "Main menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Announcement Bar"
    },
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Show announcement bar",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "Free shipping on orders over $150"
    },
    {
      "type": "url",
      "id": "announcement_link",
      "label": "Announcement link"
    },
    {
      "type": "text",
      "id": "announcement_link_text",
      "label": "Link text",
      "default": "Shop Now"
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "brand_name",
          "label": "Brand name",
          "default": "Brand Name"
        },
        {
          "type": "text",
          "id": "brand_handle",
          "label": "Brand handle",
          "info": "Used to highlight active brand (e.g., 'brand-one')"
        },
        {
          "type": "url",
          "id": "brand_link",
          "label": "Brand link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand One",
            "brand_handle": "brand-one"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand Two",
            "brand_handle": "brand-two"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand Three",
            "brand_handle": "brand-three"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand Four",
            "brand_handle": "brand-four"
          }
        },
        {
          "type": "brand",
          "settings": {
            "brand_name": "Brand Five",
            "brand_handle": "brand-five"
          }
        }
      ]
    }
  ]
}
{% endschema %}
